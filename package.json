{
  "name": "click-file",
  "displayName": "click-file",
  "description": "Highlight file names in file and make it clickable to open the file",
  "publisher": "VincesCodes",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "click-file.openFilePath",
        "title": "Open a file"
      },
      {
        "command": "click-file.openExternalFilePath",
        "title": "Open a file with external tool"
      }
    ],
    "configuration": {
      "title": "Click-File",
      "properties": {
        "click-file.externalDirectories": {
          "type": "array",
          "default": [],
          "description": "Provide a list of tool and their command to open directories"
        },
        "click-file.externalFiles": {
          "type": "array",
          "default": [],
          "description": "Provide a list of tool and their command to open files"
        },
        "click-file.remapDirectories": {
          "type": "object",
          "default": {},
          "description": "Remap part of the directory with another directory"
        },
        "click-file.linkStyle": {
          "type": "string",
          "enum": ["codelens", "documentlink"],
          "default": "codelens",
          "description": "Choose how file references should be displayed: as CodeLens buttons or as native document links"
        }
      }
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "./media/icon.png",
  "homepage": "https://github.com/Vince-s-Codes/click-file#readme",
  "bugs": {
    "url": "https://github.com/Vince-s-Codes/click-file/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Vince-s-Codes/click-file.git"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },

  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
